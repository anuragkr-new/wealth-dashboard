# Local Postgres (Docker: npm run db:up)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wealth?schema=public"

# Railway: use the DATABASE_URL from your Postgres service (Variables tab).

# --- Auth.js (Google OAuth) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# Public origin of the app (no trailing slash). Local: http://localhost:3000
# Production/staging: https://your-service.up.railway.app
AUTH_URL="http://localhost:3000"

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: only allow @gmail.com addresses (set to "true" to enable)
# AUTH_GMAIL_ONLY="true"

# Optional: seed default asset categories for one user after first Google sign-in
# SEED_FOR_EMAIL="you@gmail.com"
